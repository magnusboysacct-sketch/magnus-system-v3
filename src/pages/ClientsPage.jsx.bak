                <input value={email} onChange={function (e) { return setEmail(e.target.value); }} className="mt-1 w-full rounded-xl bg-slate-950 border border-slate-800 px-3 py-2 text-sm outline-none focus:border-slate-600"/>
              </div>
              <div>
                <label className="text-xs text-slate-400">Address</label>
                <input value={address} onChange={function (e) { return setAddress(e.target.value); }} className="mt-1 w-full rounded-xl bg-slate-950 border border-slate-800 px-3 py-2 text-sm outline-none focus:border-slate-600"/>
              </div>
            </div>

