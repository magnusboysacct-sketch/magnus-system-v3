                <input value={phone} onChange={function (e) { return setPhone(e.target.value); }} className="mt-1 w-full rounded-xl bg-slate-950 border border-slate-800 px-3 py-2 text-sm outline-none focus:border-slate-600"/>
              </div>
            </div>

