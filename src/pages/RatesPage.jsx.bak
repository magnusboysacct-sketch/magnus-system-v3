                  <div className="text-xs opacity-70 mb-1">Effective Date</div>
                  <input type="date" value={bulkEffectiveDate} onChange={function (e) { return setBulkEffectiveDate(e.target.value); }} className="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-sm outline-none focus:ring-1 focus:ring-white/20"/>
