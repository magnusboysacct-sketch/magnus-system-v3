                      <option value="percent">Percent (+/- %)</option>
                      <option value="add">Add amount (+/-)</option>
                      <option value="set">Set value</option>
                    </select>
                  </div>

                  <div>
                    <div className="text-xs opacity-70 mb-1">
                      Value {bulkMode === "percent" ? "(e.g. 8 or -3)" : bulkMode === "add" ? "(e.g. 250 or -100)" : "(e.g. 18500)"}
                    </div>
                    <input value={bulkValue} onChange={function (e) { return setBulkValue(e.target.value); }} type="number" step="0.01" className="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-sm outline-none focus:ring-1 focus:ring-white/20" placeholder={bulkMode === "percent" ? "8" : bulkMode === "add" ? "250" : "18500"}/>
                  </div>
                </div>

