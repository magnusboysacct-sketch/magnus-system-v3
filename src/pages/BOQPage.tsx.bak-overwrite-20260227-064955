                                      <button
                                        onClick={() => deleteItem(item.id, section.id)}
                                        className="px-2 py-0.5 bg-red-600 hover:bg-red-500 text-xs rounded transition-colors w-[90px]"
                                      >
                                        Delete
                                      </button>
                                    )}
                                  </div>
                                ))}
                              </div>
                            )}

                            {activeBoq?.status !== "approved" && (
                              <button
                                onClick={() => handleAddItem(section.id)}
                                className="mt-1 px-2 py-0.5 bg-slate-600 hover:bg-slate-500 text-xs rounded transition-colors"
                              >
                                Add Item
                              </button>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}

                {activeBoq?.status !== "approved" && (
                  <button
                    onClick={handleAddSection}
                    className="mt-2 px-3 py-1 bg-slate-700 hover:bg-slate-600 text-xs rounded transition-colors"
                  >
                    Add Section
                  </button>
                )}
              </div>
            )}

            {/* Grand Total */}
            {activeBoqId && items.length > 0 && (
              <div className="mt-4 pt-4 border-t border-slate-700">
                <div className="text-sm font-medium text-slate-200">Grand Total: {fmtMoney(grandTotal)}</div>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}









