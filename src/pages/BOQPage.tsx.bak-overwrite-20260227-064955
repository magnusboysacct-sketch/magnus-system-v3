import React, { useEffect, useState, useMemo } from "react";
import { useNavigate } from "react-router-dom";
import { supabase } from "../lib/supabase";

type Project = {
  id: string;
  name: string;
};

type BOQHeader = {
  id: string;
  project_id: string;
  title: string;
  status: string;
  version: number;
  created_at: string;
  updated_at?: string | null;
  project_scope?: string | null;
};

type LaborOption = { id: string; item_name: string; description: string | null; unit: string | null; unit_rate: number | null; item_type: string | null; };

type CatalogRow = {
  id: string;
  item_name: string;
  description: string | null;
  unit: string | null;
  category: string | null;
  item_type: string | null;
  current_rate: number | null;
};

export default function BOQPage() {

  async function generateEstimateFromBoq() {
    if (!activeBoqId) return;

    // Only allow from APPROVED BOQ
    if (!activeBoq || activeBoq.status !== "approved") {
      try { setBannerError("Generate Estimate is only allowed for an APPROVED BOQ. Please approve and lock this BOQ first."); } catch {}
      return;
    }

    try {
      const resp = await supabase.rpc("create_estimate_from_boq", { p_boq_id: activeBoqId });
      if (resp.error) {
        console.error("create_estimate_from_boq error:", resp.error);
        try { setBannerError(resp.error.message || "Failed to generate estimate"); } catch {}
        return;
      }
      const newEstimateId = resp.data;
      console.log(" Generated estimate id:", newEstimateId);
      try { setBannerError(" Estimate created from BOQ."); } catch {}
      // navigate("/estimates"); // optional later
    } catch (err) {
      console.error("Failed to generate estimate:", err);
      try { setBannerError("Failed to generate estimate"); } catch {}
    }
  }

  const navigate = useNavigate();
  const fmtMoney = (n: any) =>
    "J$" +
    new Intl.NumberFormat("en-JM", {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(Number(n ?? 0) || 0);

  const fmtNumber = (n: any) =>
    new Intl.NumberFormat("en-JM", { maximumFractionDigits: 2 }).format(
      Number(n ?? 0) || 0
    );

  const [projects, setProjects] = useState<Project[]>([]);
  const [selectedProjectId, setSelectedProjectId] = useState<string>("");
  const [boqHeaders, setBoqHeaders] = useState<BOQHeader[]>([]);
  const [activeBoq, setActiveBoq] = useState<BOQHeader | null>(null);
  const [activeBoqId, setActiveBoqId] = useState<string | null>(null);
  const [selectedVersionId, setSelectedVersionId] = useState<string | null>(null);
  const [sections, setSections] = useState<any[]>([]);
  const [items, setItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string>("");
  const [myRole, setMyRole] = useState<string | null>(null);
  const [bannerError, setBannerError] = useState<string | null>(null);
  const [companyLogoUrl, setCompanyLogoUrl] = useState<string | null>(null);
  const [selectedProject, setSelectedProject] = useState<any | null>(null);
  const [selectedClient, setSelectedClient] = useState<any | null>(null);
  const [projectScope, setProjectScope] = useState<string>("");
  const [laborOptions, setLaborOptions] = useState<LaborOption[]>([]);
  const [catalog, setCatalog] = useState<CatalogRow[]>([]);

  // Computed totals
  const sectionTotal = useMemo(
    () => (sectionId: string) => {
      const sectionItems = items.filter((item) => item.section_id === sectionId);
      return sectionItems.reduce((total, item) => {
        const amount = Number(item.amount ?? 0) || 0;
        return total + amount;
      }, 0);
    },
    [items]
  );

  const grandTotal = useMemo(() => {
    return items.reduce((total, item) => {
      const amount = Number(item.amount ?? 0) || 0;
      return total + amount;
    }, 0);
  }, [items]);

  // Load user role on mount
  useEffect(() => {
    async function loadUserRole() {
      try {
        const {
          data: { user },
        } = await supabase.auth.getUser();
        if (user) {
          const { data, error } = await supabase
            .from("user_profiles")
            .select("role")
            .eq("id", user.id)
            .single();

          if (error) throw error;
          setMyRole(data?.role || null);
        }
      } catch (err) {
        console.error("Failed to load user role:", err);
      }
    }

    loadUserRole();
  }, []);

  // Load company logo on mount
  useEffect(() => {
    async function loadCompanyLogo() {
      try {
        const { data } = await supabase
          .from("company_settings")
          .select("logo_url")
          .eq("id", 1)
          .single();

        setCompanyLogoUrl(data?.logo_url || null);
      } catch (err) {
        console.error("Failed to load company logo:", err);
      }
    }

    loadCompanyLogo();
  }, []);

  // Load labor options on mount
  useEffect(() => {
    async function loadLaborOptions() {
      try {
        const { data, error } = await supabase
          .from("cost_items")
          .select("id,item_name,description,unit,unit_rate,item_type")
          .ilike("item_type","lab%")
          .order("item_name", { ascending: true });

        if (error) throw error;
        setLaborOptions(data || []);
      } catch (err) {
        console.error("Failed to load labor options:", err);
      }
    }

    loadLaborOptions();
  }, []);

  // Load catalog on mount
  useEffect(() => {
    async function loadCatalog() {
      try {
        const { data, error } = await supabase
          .from("v_cost_items_current")
          .select("id,item_name,description,unit,category,item_type,current_rate")
          .order("item_name", { ascending: true });

        if (error) throw error;
        setCatalog(data || []);
      } catch (err) {
        console.error("Failed to load catalog:", err);
      }
    }

    loadCatalog();
  }, []);

  // Helper functions
  function norm(s: any) {
    const t = String(s ?? "").trim();
    return t ? t : "";
  }

  function titleCase(s: string) {
    return s.replace(/\w\S*/g, (t) => t.charAt(0).toUpperCase() + t.slice(1).toLowerCase());
  }

  // Load selected project and client when selectedProjectId changes
  useEffect(() => {
    async function loadSelectedProjectAndClient() {
      if (!selectedProjectId) {
        setSelectedProject(null);
        setSelectedClient(null);
        return;
      }

      try {
        const { data: projectData, error: projectError } = await supabase
          .from("projects")
          .select("id, name, site_address, client_id")
          .eq("id", selectedProjectId)
          .single();

        if (projectError) throw projectError;

        setSelectedProject(projectData);

        if (projectData?.client_id) {
          const { data: clientData, error: clientError } = await supabase
            .from("clients")
            .select("id, name, phone, email, address")
            .eq("id", projectData.client_id)
            .single();

          if (clientError) throw clientError;
          setSelectedClient(clientData);
        } else {
          setSelectedClient(null);
        }
      } catch (err) {
        console.error("Failed to load project/client:", err);
        setSelectedProject(null);
        setSelectedClient(null);
      }
    }

    loadSelectedProjectAndClient();
  }, [selectedProjectId]);

  // Load projects on page load
  useEffect(() => {
    async function loadProjects() {
      try {
        const { data, error } = await supabase
          .from("projects")
          .select("id, name")
          .order("name");

        if (error) throw error;
        setProjects(data || []);
      } catch (err) {
        console.error("Failed to load projects:", err);
        setError("Failed to load projects");
      } finally {
        setLoading(false);
      }
    }

    loadProjects();
  }, []);

  // ✅ Reusable loader (used by effects + Start BOQ + Clone)
  async function loadBoqHeaders(projectId: string, preferBoqId?: string) {
    try {
      setError("");
      const { data, error } = await supabase
        .from("boq_headers")
        .select("id, project_id, title, status, version, created_at, updated_at, project_scope")
        .eq("project_id", projectId)
        .order("version", { ascending: false });

      if (error) throw error;

      const headers = (data || []) as BOQHeader[];
      setBoqHeaders(headers);

      const chosen =
        (preferBoqId ? headers.find((h) => h.id === preferBoqId) : null) ||
        (headers.length > 0 ? headers[0] : null);

      setActiveBoq(chosen);
      setActiveBoqId(chosen?.id || null);
      setSelectedVersionId(chosen?.id || null);
      setProjectScope(chosen?.project_scope || "");
    } catch (err) {
      console.error("Failed to load BOQ headers:", err);
      setError("Failed to load BOQs");
      setBoqHeaders([]);
      setActiveBoq(null);
      setActiveBoqId(null);
      setSelectedVersionId(null);
      setProjectScope("");
    }
  }

  // Load BOQ headers when project changes
  useEffect(() => {
    if (!selectedProjectId) {
      setBoqHeaders([]);
      setActiveBoq(null);
      setActiveBoqId(null);
      setSelectedVersionId(null);
      setProjectScope("");
      return;
    }
    loadBoqHeaders(selectedProjectId);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [selectedProjectId]);

  // Handle version selection change
  useEffect(() => {
    if (selectedVersionId) {
      setActiveBoqId(selectedVersionId);
      const selectedHeader = boqHeaders.find((h) => h.id === selectedVersionId) || null;
      setActiveBoq(selectedHeader);
      setProjectScope(selectedHeader?.project_scope || "");
    }
  }, [selectedVersionId, boqHeaders]);

  // Extracted functions for reuse
  async function loadSections(boqIdOverride?: string | null) {
    const boqId = boqIdOverride ?? activeBoqId;
    if (!boqId) {
      setSections([]);
      return;
    }

    try {
      const { data, error } = await supabase
        .from("boq_sections")
        .select("*")
        .eq("boq_id", boqId)
        .order("section_no", { ascending: true });

      if (error) throw error;
      setSections(data || []);
    } catch (err) {
      console.error("Failed to load sections:", err);
      setError("Failed to load sections");
    }
  }

  async function loadItems(boqIdOverride?: string | null) {
    const boqId = boqIdOverride ?? activeBoqId;
    if (!boqId) {
      setItems([]);
      return;
    }

    try {
      const { data, error } = await supabase
        .from("boq_items")
        .select("*")
        .eq("boq_id", boqId)
        .order("section_id", { ascending: true })
        .order("line_no", { ascending: true });

      if (error) throw error;
      setItems(data || []);
    } catch (err) {
      console.error("Failed to load items:", err);
      setError("Failed to load items");
    }
  }

  // Load sections/items when active BOQ changes
  useEffect(() => {
    loadSections();
    loadItems();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [activeBoqId]);

  async function handlePrimaryAction() {
    if (!selectedProjectId) {
      setError("Select a project");
      return;
    }

    if (activeBoqId) {
      console.log("Active BOQ:", activeBoqId);
      return;
    }

    try {
      const { data, error } = await supabase
        .from("boq_headers")
        .insert({
          project_id: selectedProjectId,
          title: "BOQ",
          status: "draft",
          version: 1,
        })
        .select("id")
        .single();

      if (error) throw error;

      await loadBoqHeaders(selectedProjectId, data.id);
      await loadSections(data.id);
      await loadItems(data.id);
    } catch (err) {
      console.error("Failed to create BOQ:", err);
      setError("Failed to create BOQ");
    }
  }

  async function handleAddSection() {
    if (!activeBoqId) return;

    try {
      const nextSectionNo = sections.length + 1;
      const { error } = await supabase.from("boq_sections").insert({
        boq_id: activeBoqId,
        title: "New Section",
        section_no: nextSectionNo,
      });

      if (error) throw error;
      await loadSections();
    } catch (err) {
      console.error("Failed to add section:", err);
    }
  }

  async function handleAddItem(sectionId: string) {
    if (!activeBoqId) return;

    try {
      const sectionItems = items.filter((item) => item.section_id === sectionId);
      const nextLineNo = sectionItems.length + 1;

      const insertPayload: any = {
        boq_id: activeBoqId,
        section_id: sectionId,
        line_no: nextLineNo,
        item: "New Item",
        description: "",
        qty: 0,
        rate: 0,
        amount: 0,
        item_type: "",
        category: "",
      };

      const { error } = await supabase.from("boq_items").insert(insertPayload);

      if (error) {
        // If insert errors due to missing columns, retry without them
        if (error.message?.includes('column') || error.message?.includes('does not exist')) {
          const fallbackPayload = {
            boq_id: activeBoqId,
            section_id: sectionId,
            line_no: nextLineNo,
            item: "New Item",
            description: "",
            qty: 0,
            rate: 0,
            amount: 0,
          };
          await supabase.from("boq_items").insert(fallbackPayload);
        } else {
          throw error;
        }
      }

      await loadItems();
    } catch (err) {
      console.error("Failed to add item:", err);
    }
  }

  async function handleItemChange(itemId: string, field: string, value: any) {
    setItems((prevItems) =>
      prevItems.map((item) => {
        if (item.id === itemId) {
          const updatedItem = { ...item, [field]: value };

          if (field === "qty" || field === "rate") {
            const qty = field === "qty" ? value : item.qty;
            const rate = field === "rate" ? value : item.rate;
            updatedItem.amount = (Number(qty) || 0) * (Number(rate) || 0);
          }

          return updatedItem;
        }
        return item;
      })
    );
  }

  async function handleLaborSelect(itemId: string, itemName: string) {
    const selected = laborOptions.find(o => o.item_name === itemName);
    if (!selected) return;

    // Update item name
    await handleItemChange(itemId, "item", selected.item_name);
    
    // Update description if empty
    const item = items.find(i => i.id === itemId);
    if (item && (!item.description || item.description.trim() === "")) {
      await handleItemChange(itemId, "description", selected.description ?? "");
    }
    
    // Update rate if 0 or empty
    if (item && (!item.rate || item.rate === 0)) {
      await handleItemChange(itemId, "rate", Number(selected.unit_rate ?? 0));
    }
    
    // Save the item
    await saveItem(itemId);
  }

  async function saveItem(itemId: string) {
    const item = items.find((i) => i.id === itemId);
    if (!item) return;

    try {
      const updatePayload: any = {
        item: item.item,
        description: item.description,
        qty: item.qty,
        rate: item.rate,
        amount: item.amount,
      };

      // Include item_type and category if they exist on the item
      if (item.item_type !== undefined) updatePayload.item_type = item.item_type;
      if (item.category !== undefined) updatePayload.category = item.category;

      const { error } = await supabase
        .from("boq_items")
        .update(updatePayload)
        .eq("id", itemId);

      if (error) {
        // If error mentions missing columns, retry without them
        if (error.message?.includes('column') || error.message?.includes('does not exist')) {
          const fallbackPayload = {
            item: item.item,
            description: item.description,
            qty: item.qty,
            rate: item.rate,
            amount: item.amount,
          };
          await supabase
            .from("boq_items")
            .update(fallbackPayload)
            .eq("id", itemId);
        } else {
          throw error;
        }
      }
    } catch (err) {
      console.error("Failed to save item:", err);
    }
  }

  async function approveAndLock() {
    if (!activeBoqId) return;

    setBannerError(null);

    if (myRole !== "director") {
      setBannerError("Only Director can approve and lock a BOQ.");
      return;
    }

    try {
      const { error } = await supabase
        .from("boq_headers")
        .update({ status: "approved" })
        .eq("id", activeBoqId);

      if (error) {
        setBannerError(error.message);
        throw error;
      }

      await loadBoqHeaders(selectedProjectId, activeBoqId);
    } catch (err) {
      console.error("Failed to approve BOQ:", err);
      setBannerError((prev) => prev ?? "Failed to approve BOQ");
    }
  }

  async function cloneNewVersion() {
    if (!selectedProjectId || !activeBoq || !activeBoqId) return;

    try {
      setBannerError(null);

      const maxVersion = boqHeaders.length > 0 ? boqHeaders[0].version : 0;
      const newVersion = maxVersion + 1;

      const { data: newBoq, error: headerError } = await supabase
        .from("boq_headers")
        .insert({
          project_id: selectedProjectId,
          title: activeBoq.title,
          status: "draft",
          version: newVersion,
          project_scope: activeBoq.project_scope ?? "",
        })
        .select("*")
        .single();

      if (headerError) throw headerError;
      const newBoqId = newBoq.id as string;

      // Load old sections
      const { data: oldSections, error: oldSectionsErr } = await supabase
        .from("boq_sections")
        .select("*")
        .eq("boq_id", activeBoqId)
        .order("section_no");

      if (oldSectionsErr) throw oldSectionsErr;

      const sectionMap = new Map<string, string>();

      if (oldSections && oldSections.length > 0) {
        const { data: insertedSections, error: insertSectionsErr } = await supabase
          .from("boq_sections")
          .insert(
            oldSections.map((s: any) => ({
              boq_id: newBoqId,
              title: s.title,
              section_no: s.section_no,
              scope: s.scope ?? "",
            }))
          )
          .select("*");

        if (insertSectionsErr) throw insertSectionsErr;

        (oldSections as any[]).forEach((oldS, idx) => {
          const newS = (insertedSections as any[])[idx];
          if (newS) sectionMap.set(oldS.id, newS.id);
        });
      }

      // Load old items
      const { data: oldItems, error: oldItemsErr } = await supabase
        .from("boq_items")
        .select("*")
        .eq("boq_id", activeBoqId)
        .order("section_id")
        .order("line_no");

      if (oldItemsErr) throw oldItemsErr;

      if (oldItems && oldItems.length > 0) {
        const rows = (oldItems as any[]).map((it) => ({
          boq_id: newBoqId,
          section_id: sectionMap.get(it.section_id) || it.section_id,
          line_no: it.line_no,
          item: it.item,
          description: it.description,
          qty: it.qty,
          rate: it.rate,
          amount: it.amount,
        }));

        const { error: insertItemsErr } = await supabase.from("boq_items").insert(rows);
        if (insertItemsErr) throw insertItemsErr;
      }

      // Switch UI to new BOQ version
      await loadBoqHeaders(selectedProjectId, newBoqId);
      await loadSections(newBoqId);
      await loadItems(newBoqId);
    } catch (err) {
      console.error("Failed to clone new version:", err);
      setBannerError("Failed to clone new version");
    }
  }

  async function deleteItem(itemId: string, sectionId: string) {
    if (!activeBoqId) return;

    try {
      const { error: deleteError } = await supabase.from("boq_items").delete().eq("id", itemId);
      if (deleteError) throw deleteError;

      await loadItems();

      const { data: sectionItems, error: sectionItemsErr } = await supabase
        .from("boq_items")
        .select("*")
        .eq("boq_id", activeBoqId)
        .eq("section_id", sectionId)
        .order("line_no", { ascending: true });

      if (sectionItemsErr) throw sectionItemsErr;

      if (sectionItems) {
        for (let i = 0; i < sectionItems.length; i++) {
          await supabase.from("boq_items").update({ line_no: i + 1 }).eq("id", sectionItems[i].id);
        }
      }

      await loadItems();
    } catch (err) {
      console.error("Failed to delete item:", err);
      setBannerError("Failed to delete item");
    }
  }

  async function deleteSection(sectionId: string) {
    if (!activeBoqId) return;

    try {
      const { error: itemsError } = await supabase.from("boq_items").delete().eq("section_id", sectionId);
      if (itemsError) throw itemsError;

      const { error: sectionError } = await supabase.from("boq_sections").delete().eq("id", sectionId);
      if (sectionError) throw sectionError;

      await loadSections();
      await loadItems();

      const { data: remainingSections, error: remainingErr } = await supabase
        .from("boq_sections")
        .select("*")
        .eq("boq_id", activeBoqId)
        .order("section_no", { ascending: true });

      if (remainingErr) throw remainingErr;

      if (remainingSections) {
        for (let i = 0; i < remainingSections.length; i++) {
          await supabase.from("boq_sections").update({ section_no: i + 1 }).eq("id", remainingSections[i].id);
        }
      }

      await loadSections();
    } catch (err) {
      console.error("Failed to delete section:", err);
      setBannerError("Failed to delete section");
    }
  }

  function handleSectionScopeChange(sectionId: string, scope: string) {
    setSections((prev) => prev.map((s) => (s.id === sectionId ? { ...s, scope } : s)));
  }

  async function saveSectionScope(sectionId: string) {
    try {
      const section = sections.find((s) => s.id === sectionId);
      if (!section) return;

      const { error } = await supabase.from("boq_sections").update({ scope: section.scope }).eq("id", sectionId);
      if (error) throw error;
    } catch (err) {
      console.error("Failed to save section scope:", err);
      setBannerError("Failed to save section scope");
    }
  }

  function handlePrint() {
    if (!activeBoq || activeBoq.status !== "approved") {
      setBannerError("Printing is only allowed for an APPROVED BOQ. Please approve and lock this BOQ first.");
      return;
    }

    const printHtml = buildPrintHtml();
    const printWindow = window.open("", "_blank");
    if (printWindow) {
      printWindow.document.write(printHtml);
      printWindow.document.close();
      printWindow.print();
    }
  }

  async function handleStartBoq() {
    if (!selectedProjectId) return;

    try {
      setBannerError(null);

      // If a BOQ already exists, do nothing (UI should hide this button anyway)
      if (boqHeaders.length > 0) return;

      const { data, error } = await supabase
        .from("boq_headers")
        .insert({
          project_id: selectedProjectId,
          title: "BOQ",
          status: "draft",
          version: 1,
          project_scope: "",
        })
        .select("*")
        .single();

      if (error) throw error;

      await loadBoqHeaders(selectedProjectId, data.id);
      await loadSections(data.id);
      await loadItems(data.id);
    } catch (err: any) { console.error("Failed to start BOQ:", err); setBannerError("Failed to start BOQ: " + (err?.message ?? JSON.stringify(err))); }
  }

  async function saveProjectScope() {
    if (!activeBoqId) return;

    try {
      const { error } = await supabase.from("boq_headers").update({ project_scope: projectScope }).eq("id", activeBoqId);
      if (error) throw error;
    } catch (err) {
      console.error("Failed to save project scope:", err);
      setBannerError("Failed to save project scope");
    }
  }

  function buildPrintHtml() {
    const chosenProject = projects.find((p) => p.id === selectedProjectId);
    const projectTitle = chosenProject?.name || "Unknown Project";
    const boqTitle = activeBoq?.title || "Untitled BOQ";
    const boqVersion = activeBoq?.version || 1;
    const boqStatus = activeBoq?.status || "draft";
    const scopeForTerms = activeBoq?.project_scope || "";

    const termsHtml = `
<div class="terms-page">
  <h2>Terms & Conditions</h2>

  <h3>1. Scope of Work</h3>
  <p>${
    scopeForTerms
      ? scopeForTerms.replace(/</g, "&lt;").replace(/>/g, "&gt;")
      : "The works described in this Bill of Quantities (BOQ) are based on the project information provided. Any additional works not included herein will be treated as a variation and may affect cost and time."
  }</p>

